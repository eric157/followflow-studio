# Version control
.git
.gitignore

# Python byte-code & caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/

# Local build output
build/
dist/
*.spec

# Local release archives (can be 50+ MB)
*.zip

# Runtime / user data (never bake personal data into the image)
data/runtime/
data/processed/
data/exports/

# Editor / OS noise
.DS_Store
Thumbs.db
*.log
*.tmp
.idea/
.vscode/

# CI / GitHub (not needed inside container)
.github/
